{
	"name": "real-pin",
	"version": "1.1.0",
	"description": "Confirms before closing a pinned tab via any close hotkey or command.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"build": "npm run typecheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"validate": "node scripts/validate-plugin.mjs",
		"test": "node --test scripts/*.test.mjs",
		"test:e2e": "node --test test/e2e/*.e2e.mjs",
		"check": "npm run validate && npm run lint && npm run typecheck && npm test",
		"version": "node version-bump.mjs && node scripts/validate-plugin.mjs && git add manifest.json versions.json",
		"prepare": "git config core.hooksPath .githooks || true"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"pin",
		"tabs"
	],
	"author": "Greg Brown",
	"license": "MIT",
	"dependencies": {
		"monkey-around": "^2.3.0"
	},
	"devDependencies": {
		"@types/node": "^16.11.6",
		"chrome-remote-interface": "^0.34.0",
		"esbuild": "^0.20.2",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.7.0",
		"obsidian": "~1.13.1",
		"obsidian-launcher": "^3.1.1",
		"tslib": "^2.6.2",
		"typescript": "^5.4.5",
		"typescript-eslint": "^8.62.0"
	}
}
